VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-only (never in VITE_ prefix or client bundle)
# DATABASE_URL: Supabase pooler (porta 6543) — obrigatório para serverless
DATABASE_URL=postgresql://project-user:password@aws-X-region-N.pooler.supabase.com:6543/postgres
# DIRECT_URL: conexão direta (porta 5432) — apenas para migrations
DIRECT_URL=postgresql://project-user:password@aws-X-region-N.pooler.supabase.com:5432/postgres
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional secure bootstrap for the first primary administrator.
PRIMARY_ADMIN_EMAIL=admin@artec.com
PRIMARY_ADMIN_PASSWORD=change-this-strong-password1
PRIMARY_ADMIN_NAME=Administrador Principal

# E2E Playwright user. Override locally if needed.
E2E_TEST_EMAIL=e2e@artec.com
E2E_TEST_PASSWORD=artec26
