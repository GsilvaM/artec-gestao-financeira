{
  "buildCommand": "prisma generate && prisma migrate deploy && bun run build",
  "installCommand": "bun install",
  "outputDirectory": "dist",
  "functions": {
    "api/financeiro.ts": {
      "includeFiles": "src/**"
    }
  },
  "rewrites": [
    { "source": "/api/financeiro/:path*", "destination": "/api/financeiro" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
