{
  "buildCommand": "bun run db:deploy && bun run build",
  "installCommand": "bun install",
  "outputDirectory": "dist",
  "functions": {
    "api/financeiro.ts": {
      "includeFiles": "src/**"
    },
    "api/admin.ts": {
      "includeFiles": "src/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/admin/:path*",
      "destination": "/api/admin"
    },
    {
      "source": "/api/financeiro/:path*",
      "destination": "/api/financeiro"
    },
    {
      "source": "/((?!api/)(?!.*\\.(?:js|css|json|png|svg|ico|webmanifest|txt|xml)$).*)",
      "destination": "/index.html"
    }
  ]
}
