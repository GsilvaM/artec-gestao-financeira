{
  "buildCommand": "prisma generate && prisma migrate deploy && bun run build",
  "installCommand": "bun install",
  "outputDirectory": "dist",
  "functions": {
    "api/financeiro/[...slug].ts": {
      "includeFiles": "src/**"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
